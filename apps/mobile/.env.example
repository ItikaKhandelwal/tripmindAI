# ================================
# TripMind - React Native Expo App
# Copy this file to .env and fill in your real values
# Note: These values also go into app.json under "extra"
# ================================

# Supabase
SUPABASE_URL=https://shhndttpmszdrksediqc.supabase.co
SUPABASE_ANON_KEY=YOUR_ANON_KEY_HERE

# FastAPI backend URL
# For local dev use your computer's local IP (not localhost)
# because the phone can't reach your computer via "localhost"
API_URL=http://192.168.x.x:8000
# Find your local IP by running: ipconfig
# Look for "IPv4 Address" under your WiFi adapter
# When deployed:
# API_URL=https://tripmind-api.railway.app