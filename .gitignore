cat > .gitignore << 'EOF'
# Python
__pycache__/
*.pyc
.env
venv/

# Node
node_modules/
.next/
dist/

# Expo
.expo/
*.jks
*.p8
*.p12
*.key
*.mobileprovision

# Misc
.DS_Store
*.log
EOF

# Environment files - NEVER commit these
.env
.env.local
.env.development
.env.production
.env.staging

# But DO commit the example files
!.env.example